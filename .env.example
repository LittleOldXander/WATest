# Copy to .env for local (non-Docker) runs. Docker Compose sets these
# directly in docker-compose.yml; this file documents the same variables.

PORT=3000
NODE_ENV=development

MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=banners
MONGODB_SERVER_SELECTION_TIMEOUT_MS=3000
MONGODB_MAX_POOL_SIZE=20

REDIS_URL=redis://localhost:6379
REDIS_CONNECT_TIMEOUT_MS=2000
REDIS_COMMAND_TIMEOUT_MS=500

CACHE_IN_MEMORY_TTL_MS=5000
CACHE_IN_MEMORY_MAX_ITEMS=500
CACHE_REDIS_TTL_SECONDS=30

CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_RESET_TIMEOUT_MS=10000

LEASE_TTL_MS=5000
LEASE_WAIT_TIMEOUT_MS=3000
LEASE_POLL_INTERVAL_MS=100
LEASE_POLL_JITTER_MS=50

LOG_LEVEL=info
LOG_PRETTY=true
