{
  "name": "banner-delivery-service",
  "version": "1.0.0",
  "private": true,
  "description": "High-scale promotional banner delivery service with three-level caching, request collapsing, and cross-instance single-flight coordination.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "jest --config jest.config.cjs --runInBand",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage --runInBand",
    "test:integration": "jest --config jest.integration.config.cjs --runInBand",
    "test:load": "docker compose -f docker-compose.yml -f docker-compose.loadtest.yml up --build --abort-on-container-exit k6",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "envalid": "^8.0.0",
    "fastify": "^5.3.2",
    "ioredis": "^5.4.1",
    "lru-cache": "^11.0.1",
    "mongodb": "^6.9.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.2",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "ioredis-mock": "^8.9.0",
    "jest": "^30.0.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0"
  }
}
